# Copy to .env and fill in. .env is gitignored — never commit your key.
# Any OpenAI-compatible chat-completions endpoint works. Free options:
#
#   Groq      AEM_LLM_URL=https://api.groq.com/openai/v1/chat/completions
#             AEM_LLM_MODEL=llama-3.1-8b-instant
#   OpenRouter AEM_LLM_URL=https://openrouter.ai/api/v1/chat/completions
#             AEM_LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free
#   NVIDIA NIM AEM_LLM_URL=https://integrate.api.nvidia.com/v1/chat/completions
#             AEM_LLM_MODEL=meta/llama-3.1-8b-instruct

AEM_LLM_URL=
AEM_LLM_KEY=
AEM_LLM_MODEL=meta-llama/llama-3.1-8b-instruct
