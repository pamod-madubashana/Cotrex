# Copy to .env and fill in. .env is gitignored — never commit your key.
# Any OpenAI-compatible chat-completions endpoint works. Free options:
#
#   Groq      TOKEX_LLM_URL=https://api.groq.com/openai/v1/chat/completions
#             TOKEX_LLM_MODEL=llama-3.1-8b-instant
#   OpenRouter TOKEX_LLM_URL=https://openrouter.ai/api/v1/chat/completions
#             TOKEX_LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free
#   NVIDIA NIM TOKEX_LLM_URL=https://integrate.api.nvidia.com/v1/chat/completions
#             TOKEX_LLM_MODEL=meta/llama-3.1-8b-instruct

TOKEX_LLM_URL=
TOKEX_LLM_KEY=
TOKEX_LLM_MODEL=meta-llama/llama-3.1-8b-instruct
